FROM node:20-alpine

# Install development dependencies and Python (often required for MCPs or local scripts)
RUN apk add --no-cache git bash curl python3 py3-pip shadow sudo

ARG USERNAME=user
ARG USER_UID=1000
ARG USER_GID=1000

# Modify the default node user (UID 1000) to match the host user
RUN groupmod -g ${USER_GID} -n ${USERNAME} node && \
    usermod -u ${USER_UID} -g ${USER_GID} -d /home/${USERNAME} -m -l ${USERNAME} node

# Ensure the non-root user has a proper NPM prefix and home directory setup
ENV NPM_CONFIG_PREFIX=/home/${USERNAME}/.npm-global
ENV PATH=$PATH:/home/${USERNAME}/.npm-global/bin

RUN mkdir -p /home/${USERNAME}/.npm-global /workspace && \
    chown -R ${USERNAME}:${USERNAME} /home/${USERNAME} /workspace

# Switch to the non-root user
USER ${USERNAME}

# Install Opencode and MCP servers globally as the non-root user
RUN npm install -g opencode-ai jcodemunch-mcp jdocmunch-mcp

# Set up the working directory
WORKDIR /workspace

# Default command to start opencode
CMD ["opencode"]
