# AI Worker Environment Configuration
# This file is sourced by the guest VM's .bashrc or init script.

# --- Agent Configuration ---
export ROLE="{{ROLE}}"
export CORE_PATH="{{VM_HOME}}/.agents/core-worker"
export WORKFLOWS_DIR="${CORE_PATH}/workflows"
export RULES_DIR="${CORE_PATH}/rules"
export SKILLS_DIR="${CORE_PATH}/skills"

# --- Workspace Configuration ---
export WORKSPACE_ROOT="/workspace"
export HOST_WORKSPACE_PATH="{{HOST_WORKSPACE_PATH}}"

# --- Tooling Configuration ---
export UV_CACHE_DIR="/workspace/.uv_cache"
export PATH="{{VM_HOME}}/.local/bin:${PATH}"
