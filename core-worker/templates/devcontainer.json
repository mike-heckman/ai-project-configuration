{
    "name": "Opencode Sandbox",
    "image": "opencode-sandbox:latest",
    // Dev Containers usually maps the workspace automatically, 
    // but we need to pass through the Opencode state/config mounts
    "mounts": [
        "source=${localEnv:HOME}/.config/opencode,target=/home/mike/.config/opencode,type=bind",
        "source=${localEnv:HOME}/.local/share/opencode,target=/home/mike/.local/share/opencode,type=bind",
        "source=${localEnv:HOME}/.agents,target=/home/mike/.agents,type=bind,readonly"
    ],
    // Pass through your local environment variables
    "containerEnv": {
        "ANTHROPIC_BASE_URL": "http://100.117.201.1:1234/",
        "ANTHROPIC_API_KEY": "sk-ant-dummy-key"
    },
    "forwardPorts": [
        4096
    ],
    "customizations": {
        "vscode": {
            "settings": {},
            "extensions": [
                // Any VS code extensions you want loaded automatically
            ]
        }
    }
}